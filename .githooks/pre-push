#!/bin/sh

remote_name="$1"
remote_url="$2"

if [ "$remote_name" != "origin" ]; then
  exit 0
fi

if ! git fetch origin developer >/dev/null 2>&1; then
  echo "[pre-push] Failed to fetch origin/developer. Push aborted."
  exit 1
fi

current_branch=$(git branch --show-current)

if [ -z "$current_branch" ]; then
  echo "[pre-push] Detached HEAD detected. Push aborted."
  exit 1
fi

if ! git merge-base --is-ancestor origin/developer HEAD; then
  echo "[pre-push] Your branch is behind origin/developer. Run: git pull --rebase origin developer"
  exit 1
fi

exit 0
